# Godot 4+ specific ignores
.godot/
/android/

# Local AI/editor task state.
/.claude/

# Local safety copies created before historical ownership migrations.
/tools/historical_ownership/backups/

# Python bytecode caches from the map tooling.
__pycache__/

# Windows lock/temp copies left behind when a plugin DLL is rebuilt while loaded.
~*.dll
~*.dll~*.TMP

# Cached elevation source raster downloaded by build_heightmap.py.
/tools/terrain/gebco_08_rev_elev_5400x2700.jpg

# Transient headless/editor parser and run logs.
*.log
